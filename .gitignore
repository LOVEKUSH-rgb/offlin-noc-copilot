# =============================================================================
# .gitignore — Air-Gapped NOC Copilot
# =============================================================================

# ---------------------------------------------------------------------------
# Virtual Environments
# ---------------------------------------------------------------------------
venv/
.venv/
env/
ENV/
virtualenv/
.virtualenv/
*.egg-info/
dist/
build/

# ---------------------------------------------------------------------------
# Python Cache
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ---------------------------------------------------------------------------
# Streamlit Temporary / Cache Files
# ---------------------------------------------------------------------------
.streamlit/
*.streamlit/
**/.streamlit/secrets.toml

# ---------------------------------------------------------------------------
# Jupyter Notebooks
# ---------------------------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# OS & Editor Artifacts
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Environment Variables & Secrets
# ---------------------------------------------------------------------------
.env
.env.*
secrets.toml
*.pem
*.key

# ---------------------------------------------------------------------------
# Logs & Temporary Files
# ---------------------------------------------------------------------------
*.log
*.tmp
*.bak
logs/
tmp/

# ---------------------------------------------------------------------------
# Data & Model Artifacts (large binary files)
# ---------------------------------------------------------------------------
*.csv
*.pkl
*.h5
*.pt
*.onnx
data/raw/
models/weights/
